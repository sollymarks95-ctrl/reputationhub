{
  "framework": "nextjs",
  "buildCommand": "npx next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron-update?secret=REDACTED_CRON_SECRET&batch=0",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron-update?secret=REDACTED_CRON_SECRET&batch=1",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-update?secret=REDACTED_CRON_SECRET&batch=2",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-update?secret=REDACTED_CRON_SECRET&batch=3",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-update?secret=REDACTED_CRON_SECRET&batch=4",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/admin/regenerate-images?secret=REDACTED_CRON_SECRET&limit=150",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron-reviews?secret=REDACTED_CRON_SECRET",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-companies?secret=REDACTED_CRON_SECRET",
      "schedule": "0 6 * * *"
    }
  ]
}